# R specific gitignores
.Rprofile
.Rhistory
.Rprofile
.Ruserdata
.DS_Store
*.Rproj
.Rproj.user
.venv/
__pycache__/
*.pyc

## ignore the renv initialization file
initialize_renv.R

## ignore filtered CLIF tables stored as Rdata
*.RData

# ignore local CLIF source tables if they ever appear in-repo
CLIF_*.parquet
CLIF_*.csv
CLIF_*.fst
clif_*.parquet
clif_*.csv
clif_*.fst

#ignore the identifier app
CLIF_cohort_identifier*

# ignore file used to initialize renv when creating the template
initialize_renv.R

# ignore filtered CLIF tables stored as Rdata
*.RData

# ignore pdf reports and rendered html
*.pdf
*.html

# ignore local config with site-specific paths
config/config.json

# ignore patient-level or site-level intermediate outputs
output/intermediate/**
output/logs/**

# ignore local key template copies, but keep actual key fragment CSVs visible
keys/templates/**

# keep top-level output documentation and final aggregate examples
!output/README.md
!output/final/
!output/final/**
